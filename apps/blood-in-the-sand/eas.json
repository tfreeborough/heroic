{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_DEFAULT_SERVER": "blood-in-the-sand.onrender.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DEFAULT_SERVER": "blood-in-the-sand.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DEFAULT_SERVER": "blood-in-the-sand.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
