# Copy to .env.local (that pattern is git-ignored; bare .env is NOT — see the
# realmsmith incident). EXPO_PUBLIC_* is inlined into the JS bundle at build
# time — restart Metro / rebuild after changing.

# Pre-fills the join screen's server address. Point it at the Render service
# once the blueprint is deployed (bare hostname → wss on 443).
EXPO_PUBLIC_DEFAULT_SERVER=blood-in-the-sand.onrender.com

# Optional: skip the join form entirely on launch (simulator dev loop).
# EXPO_PUBLIC_AUTO_HOST=localhost
