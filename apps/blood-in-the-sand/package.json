  "main": "index.ts",
  "dependencies": {
    "@heroic/blood-in-the-sand-sim": "workspace:*",
    "@heroic/core": "workspace:*",
    "@heroic/engine": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "~56.0.9",
    "expo-asset": "~56.0.16",
    "expo-audio": "~56.0.12",
    "expo-clipboard": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-haptics": "~56.0.3",
    "expo-keep-awake": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "ios": "APP_VARIANT=development expo run:ios",
    "ios:device": "APP_VARIANT=development expo run:ios --device",
    "android": "APP_VARIANT=development expo run:android",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:android:dev": "eas build --platform android --profile development",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:android:preview": "eas build --platform android --profile preview",
    "typecheck": "tsc --noEmit"
  },
  "private": true
