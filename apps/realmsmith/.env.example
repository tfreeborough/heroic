# Asset Forge provider keys (docs/design/asset-forge.md).
# Copy this file to `.env.local` (gitignored) and fill in real keys, then restart
# the dev server. Names deliberately have no VITE_ prefix — Vite never exposes
# them to browser code; only the forge plugin (dev server) reads them.
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
