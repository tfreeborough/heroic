# dependencies
node_modules/

# expo
.expo/
dist/
web-build/
*.orig.*
.expo-shared/

# native
ios/
android/
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# google play service account credential (used by eas submit, never committed)
play-service-account.json

# local dev database (blood-in-the-sand-api without Turso creds)
dev.db*

# misc
.DS_Store
*.log
# env files are never committed, with ONE exception: the BITS client's
# .env.production holds only EXPO_PUBLIC_* values (public URLs inlined into
# the shipped app bundle — nothing secret) and is the single source every
# production bundle is built against (eas update + EAS build). Server-side
# env (Turso creds etc.) stays ignored.
.env*
!apps/blood-in-the-sand/.env.production
.idea/
.vscode/

# bun
# (bun.lock is committed; lockb binary is also fine to commit)
